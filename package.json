{
  "name": "midnight-ledger",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "build:web": "tsc -b && vite build",
    "build:win": "npm run build:web && electron-builder --win portable",
    "make:icon": "node scripts/make-icon.mjs",
    "verify:desktop": "npm run build:web && npx electron scripts/electron-smoke-test.cjs",
    "package:desktop": "node scripts/package-desktop.mjs",
    "test": "vitest run",
    "test:parser": "npx tsx scripts/verify-parser.ts",
    "test:e2e": "npm run build:web && npx electron scripts/desktop-e2e.cjs",
    "test:packaged": "node scripts/packaged-launch-test.cjs",
    "test:all": "npm run test && npm run test:parser && npm run verify:desktop"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "framer-motion": "^11.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.15.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.9"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.midnightledger.app",
    "productName": "Midnight Ledger",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Midnight Ledger.exe"
    },
    "nsis": {
      "include": "build/installer.nsh"
    }
  }
}
